# Supabase — copia questo file in .env.local e compila i valori
# Trovi questi valori in: Supabase Dashboard > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL pubblica dell'app (usata per i redirect OAuth/magic link)
# In sviluppo: http://localhost:3000
# In produzione: https://tuo-dominio.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
